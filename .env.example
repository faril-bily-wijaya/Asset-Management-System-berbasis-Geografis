# ==============================================
# Map Inventory - Environment Variables
# ==============================================

# API Configuration
VITE_API_URL=http://localhost:3001/api

# Enable/Disable API Backend Sync
# Set to 'true' to sync data with backend database
# Set to 'false' or leave empty to use localStorage only (offline mode)
VITE_USE_API=false

# ==============================================
# Example Usage:
# ==============================================
#
# DEVELOPMENT (localStorage only - default):
# VITE_USE_API=false
# VITE_API_URL=http://localhost:3001/api
#
# PRODUCTION (with backend database):
# VITE_USE_API=true
# VITE_API_URL=https://your-api-server.com/api
#
# ==============================================
